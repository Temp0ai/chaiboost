# ============================================
# ChaiBoost Environment Variables
# ============================================

# --- Server ---
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000

# --- PostgreSQL ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=chaiboost
DB_USER=chaiboost
DB_PASSWORD=chaiboost_dev_password
DATABASE_URL=postgresql://chaiboost:chaiboost_dev_password@localhost:5432/chaiboost

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379

# --- JWT ---
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-token-secret-change-in-production
JWT_REFRESH_EXPIRES_IN=30d

# --- Encryption (AES-256-GCM) ---
ENCRYPTION_KEY=your-32-byte-encryption-key-here
ENCRYPTION_IV_LENGTH=16

# --- AI Services ---
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o
OPENAI_VISION_MODEL=gpt-4o
OPENAI_IMAGE_MODEL=dall-e-3

# --- Instagram (Meta Graph API) ---
INSTAGRAM_APP_ID=your-instagram-app-id
INSTAGRAM_APP_SECRET=your-instagram-app-secret
INSTAGRAM_REDIRECT_URI=http://localhost:3000/api/auth/instagram/callback

# --- Google My Business ---
GMB_CLIENT_ID=your-google-client-id
GMB_CLIENT_SECRET=your-google-client-secret
GMB_REDIRECT_URI=http://localhost:3000/api/auth/gmb/callback
GMB_API_KEY=your-google-api-key

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret
STRIPE_PRICE_STARTER=price_starter_monthly_id
STRIPE_PRICE_GROWTH=price_growth_monthly_id
STRIPE_PRICE_PRO=price_pro_monthly_id

# --- File Storage (S3 / Cloudflare R2) ---
STORAGE_ENDPOINT=https://your-r2-endpoint.r2.cloudflarestorage.com
STORAGE_BUCKET=chaiboost-assets
STORAGE_ACCESS_KEY=your-storage-access-key
STORAGE_SECRET_KEY=your-storage-secret-key
STORAGE_PUBLIC_URL=https://assets.chaiboost.app

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# --- Logging ---
LOG_LEVEL=debug
