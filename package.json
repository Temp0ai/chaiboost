{
  "name": "chaiboost",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/shared",
    "packages/backend",
    "packages/mobile"
  ],
  "scripts": {
    "dev:backend": "npm run dev --workspace=packages/backend",
    "dev:mobile": "npm run start --workspace=packages/mobile",
    "build:shared": "npm run build --workspace=packages/shared",
    "build:backend": "npm run build --workspace=packages/backend",
    "db:migrate": "npm run db:migrate --workspace=packages/backend",
    "db:seed": "npm run db:seed --workspace=packages/backend",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspace=packages/backend"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
